# default configuration
OCI_REGISTRY_URL=0.0.0.0
OCI_REGISTRY_PORT=8968
OCI_REGISTRY_STORAGE=FILESYSTEM
OCI_REGISTRY_ROOTDIR=/var/lib/oci-registry
OCI_REGISTRY_PUBLIC_URL=http://127.0.0.1:8968

# localhost if you don't use docker
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

JWT_SECRET="secret"
JWT_LIFETIME_SECONDS=3600

RUST_LOG="info"
PROFILE=debug

GITHUB_CLIENT_ID=github_client_id
GITHUB_CLIENT_SECRET=github_client_secret

# S3 storage backend (effective only when OCI_REGISTRY_STORAGE=S3)
# OCI_REGISTRY_S3_BUCKET=my-registry
# OCI_REGISTRY_S3_REGION=us-east-1
# OCI_REGISTRY_S3_ENDPOINT=http://minio:9000
# OCI_REGISTRY_S3_ACCESS_KEY_ID=minioadmin
# OCI_REGISTRY_S3_SECRET_ACCESS_KEY=minioadmin
# OCI_REGISTRY_S3_PATH_STYLE=true
# OCI_REGISTRY_S3_ALLOW_HTTP=true
